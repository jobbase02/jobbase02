# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# ── Supabase (public — safe to expose to browser, protected by RLS) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key          # Settings → API → anon public

# ── Supabase service role (server-only, NEVER expose to browser) ─────────────
SUPABASE_SERVICE_KEY=your-service-role-key            # Settings → API → service_role

# ── OpenAI — query embedding in /api/ai-search (server-only) ─────────────────
OPENAI_API_KEY=sk-...

# ── Grok (xAI) — AI chat completion in /api/ai-search (server-only) ──────────
# Get from: https://console.x.ai
GROK_API_KEY=xai-...

# ── Telegram Bot (server-only) ────────────────────────────────────────────────
BOT_TOKEN=123456789:AAF...                            # from @BotFather
BOT_WEBHOOK_SECRET=any-random-32-char-string          # run setup_bot.py to auto-generate

# ── App public URL — used by the bot to build the Mini App link ───────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app       # your Vercel deployment URL
