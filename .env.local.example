# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── OpenAI — query embedding in /api/ai-search ────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Grok (xAI) — AI chat completion in /api/ai-search ────────────────────────
GROK_API_KEY=xai-...

# ── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:AAF...
BOT_WEBHOOK_SECRET=any-random-32-char-string
BOT_USERNAME=jobbase02_bot

# ── App public URL ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://localhost:3000

# ── Telegram Channel (for /api/channel-post) ──────────────────────────────────
# Your channel @username (e.g. @jobbasechannel) or numeric ID (e.g. -1001234567890)
TELEGRAM_CHANNEL_ID=@yourchannel
# Secret key the scraper sends in x-api-key header to POST /api/channel-post
CHANNEL_POST_SECRET=
